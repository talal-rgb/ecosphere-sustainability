# Terrnix Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# ============================================
# ZOHO SMTP — Email Notifications
# ============================================
# Zoho Mail SMTP settings:
#   Host: smtp.zoho.com (or smtp.zoho.eu for EU accounts)
#   Port: 587 (TLS) or 465 (SSL)
#   User: Your Zoho email address
#   Pass: App-specific password (NOT your account password)
#
# To create an app password:
#   1. Log in to Zoho Mail
#   2. Settings → Security → App-Specific Passwords
#   3. Generate password for "Terrnix Backend"
#   4. Copy the password here

ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=notifications@terrnix.com
ZOHO_SMTP_PASS=your-app-specific-password-here

# Where contact form submissions and newsletter signups are sent
CONTACT_TO_EMAIL=tallal@terrnix.com

# ============================================
# BREVO — Newsletter / Contact List
# ============================================
# Brevo (formerly Sendinblue) API key:
#   1. Sign up at https://www.brevo.com
#   2. Dashboard → SMTP & API → API Keys
#   3. Generate a v3 API key
#   4. Copy the key here
#
# Brevo List ID:
#   1. Dashboard → Contacts → Lists
#   2. Create a list (e.g. "Terrnix Newsletter")
#   3. Note the List ID number

BREVO_API_KEY=your-brevo-api-key-here
BREVO_LIST_ID=4

# ============================================
# LEAD STORAGE — File-based persistence fallback
# ============================================
# When email or Brevo integrations fail, leads are saved to a local
# JSONL file. This ensures no contact or newsletter signup is lost.
#
# LEADS_FILE_PATH: Absolute or relative path to the JSONL file.
#   Default: ./data/leads.jsonl (relative to backend/)
# LEADS_MAX_SIZE_MB: Maximum file size before rejections.
#   Default: 10

LEADS_FILE_PATH=./data/leads.jsonl
LEADS_MAX_SIZE_MB=10

# ============================================
# ADMIN / DEBUG
# ============================================
# ADMIN_API_TOKEN: Secret token for accessing admin endpoints
#   (e.g. /api/admin/lead-stats). Generate a strong random string.
#   If not set, admin endpoints return 503.

ADMIN_API_TOKEN=generate-a-strong-random-token-here

# ============================================
# OPENAI — Chatbot
# ============================================
OPENAI_API_KEY=sk-proj_REPLACE_WITH_YOUR_KEY
OPENAI_MODEL=gpt-5.4-mini

# ============================================
# CARBON DATA APIs
# ============================================
CLIMATIQ_API_KEY=REPLACE_WITH_CLIMATIQ_KEY
ELECTRICITYMAPS_API_KEY=REPLACE_WITH_ELECTRICITY_MAPS_KEY

# ============================================
# REPORTING
# ============================================
REPORT_BRAND_NAME=Terrnix Sustainability Intelligence
REPORT_CONTACT_EMAIL=info@terrnix.com

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=production
ALLOWED_ORIGIN=https://terrnix.com
